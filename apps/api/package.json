{
	"name": "@innolope/api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc --build",
		"start": "node dist/index.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"migrate:featured-images": "tsx src/scripts/migrate-featured-images.ts",
		"license:generate": "tsx src/scripts/generate-license.ts",
		"refresh-popular-models": "tsx scripts/refresh-popular-models.ts",
		"clean": "rm -rf dist *.tsbuildinfo"
	},
	"dependencies": {
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^11.2.0",
		"@fastify/formbody": "^8.0.2",
		"@fastify/helmet": "^13.0.2",
		"@fastify/multipart": "^9.4.0",
		"@fastify/rate-limit": "^10.3.0",
		"@fastify/static": "^9.1.3",
		"@innolope/config": "workspace:*",
		"@innolope/db": "workspace:*",
		"@innolope/types": "workspace:*",
		"@node-saml/node-saml": "^5.1.0",
		"@sentry/node": "^10.55.0",
		"aws4fetch": "^1.0.20",
		"bcrypt": "^6.0.0",
		"drizzle-orm": "^0.45.2",
		"fast-xml-parser": "^4.5.6",
		"fastify": "^5.8.5",
		"fastify-plugin": "^5.1.0",
		"firebase-admin": "^13.10.0",
		"image-size": "^2.0.2",
		"isomorphic-dompurify": "^3.15.0",
		"jose": "^6.2.3",
		"marked": "^16.4.2",
		"mongodb": "^7.2.0",
		"mysql2": "^3.22.4",
		"nodemailer": "^8.0.10",
		"openid-client": "^6.8.4",
		"pino-pretty": "^13.1.3",
		"postgres": "^3.4.9",
		"posthog-node": "^5.35.11",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/nodemailer": "^8.0.0",
		"@vitest/coverage-v8": "^4.1.8",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}

{
	"name": "@innolope/db",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		},
		"./schema": {
			"import": "./dist/schema/index.js",
			"types": "./dist/schema/index.d.ts",
			"default": "./src/schema/index.ts"
		}
	},
	"scripts": {
		"build": "tsc --build",
		"clean": "rm -rf dist *.tsbuildinfo",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/seed.ts"
	},
	"dependencies": {
		"bcrypt": "^6.0.0",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/node": "^25.9.2",
		"drizzle-kit": "^0.31.10",
		"typescript": "^6.0.3"
	}
}

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/innolope

# Auth
AUTH_SECRET=change-me-to-a-random-string
# Optional dedicated signing key for remote-MCP OAuth access tokens (min 32 chars).
# Falls back to AUTH_SECRET when unset; set it to isolate MCP tokens from web sessions.
MCP_JWT_SECRET=

# API
API_PORT=3001
API_HOST=0.0.0.0
# Externally-reachable origin, used in OAuth/MCP discovery URLs when the CMS is
# behind a proxy/CDN (e.g. https://cms.example.com). Falls back to request host.
PUBLIC_URL=

# Admin UI
VITE_API_URL=http://localhost:3001
# Google Analytics 4 (optional — leave blank to disable gtag.js entirely)
VITE_GA_MEASUREMENT_ID=

# Cloudflare (optional — falls back to local filesystem)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGES_ACCOUNT_HASH=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_IMAGES_VARIANT=
# One-click "Connect Cloudflare" OAuth (leave unset to disable; see docs/integrations/cloudflare-media.md)
CLOUDFLARE_OAUTH_CLIENT_ID=
CLOUDFLARE_OAUTH_CLIENT_SECRET=
CLOUDFLARE_OAUTH_REDIRECT_URI=
# 32-byte base64 key for encrypting integration tokens at rest (alias of SSO_ENCRYPTION_KEY)
INTEGRATION_ENCRYPTION_KEY=

# Unsplash (optional — enables stock photo search)
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# Email (optional — falls back to console logging)
# Option 1: Resend
RESEND_API_KEY=
# Option 2: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Shared
EMAIL_FROM=Innolope CMS <noreply@innolope.com>

# Analytics (optional — enables PostHog event tracking for content, auth, and MCP usage)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_DISABLED=true

# Error tracking (optional)
SENTRY_DSN=
